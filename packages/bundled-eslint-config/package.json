{
  "name": "bundled-eslint-config",
  "version": "0.8.1",
  "description": "A preset for ESLint",
  "keywords": [
    "eslint",
    "eslint preset",
    "preset",
    "typescript eslint preset",
    "typescript-eslint",
    "vue eslint preset",
    "astro eslint preset",
    "vitest eslint preset",
    "react eslint preset"
  ],
  "homepage": "https://github.com/DaniFoldi/bundled-lint-config#readme",
  "bugs": {
    "url": "https://github.com/DaniFoldi/bundled-lint-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DaniFoldi/bundled-lint-config.git"
  },
  "license": "MIT",
  "author": "DaniFoldi",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "prelint": "pnpm build",
    "lint": "eslint --cache .",
    "prepublishOnly": "pnpm build",
    "test": "vitest",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/json": "^1.2.0",
    "astro-eslint-parser": "^1.4.0",
    "defu": "^6.1.7",
    "eslint-config-flat-gitignore": "^2.3.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-package-json": "^0.91.1",
    "eslint-plugin-vue": "^10.9.0",
    "find-up": "^8.0.0",
    "globals": "^17.5.0",
    "jsonc-eslint-parser": "^3.1.0",
    "typescript-eslint": "^8.59.0",
    "vue-eslint-parser": "^10.4.0"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "some-tsconfig-preset": "3.0.1",
    "tsdown": "0.21.10",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "peerDependencies": {
    "eslint": "^10.2.1"
  }
}
