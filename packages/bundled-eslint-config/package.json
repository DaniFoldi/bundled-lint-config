{
  "name": "bundled-eslint-config",
  "version": "0.8.0",
  "description": "A preset for ESLint",
  "keywords": [
    "eslint",
    "eslint preset",
    "preset",
    "typescript eslint preset",
    "typescript-eslint",
    "vue eslint preset",
    "astro eslint preset",
    "vitest eslint preset",
    "react eslint preset"
  ],
  "homepage": "https://github.com/DaniFoldi/bundled-lint-config#readme",
  "bugs": {
    "url": "https://github.com/DaniFoldi/bundled-lint-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DaniFoldi/bundled-lint-config.git"
  },
  "license": "MIT",
  "author": "DaniFoldi",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "prelint": "pnpm build",
    "lint": "eslint --cache .",
    "prepublishOnly": "pnpm build",
    "test": "vitest",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@brettz9/eslint-plugin": "^3.0.0",
    "@eslint/compat": "^2.0.3",
    "@eslint/json": "^1.2.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitest/eslint-plugin": "^1.6.13",
    "astro-eslint-parser": "^1.4.0",
    "defu": "^6.1.4",
    "eslint-config-flat-gitignore": "^2.3.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-case-police": "^2.2.0",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-import-zod": "^1.2.1",
    "eslint-plugin-jsdoc": "^62.8.1",
    "eslint-plugin-json-schema-validator": "^6.2.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-package-json": "^0.91.1",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "find-up": "^8.0.0",
    "globals": "^17.4.0",
    "jsonc-eslint-parser": "^3.1.0",
    "typescript-eslint": "^8.58.0",
    "vue-eslint-parser": "^10.4.0"
  },
  "devDependencies": {
    "@types/node": "24.12.0",
    "jiti": "2.6.1",
    "some-tsconfig-preset": "3.0.1",
    "tsdown": "0.21.7",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  },
  "peerDependencies": {
    "eslint": "^10.1.0"
  }
}
